# --- FINSIGHT RAG : ENVIRONMENT VARIABLES ---
# Copy this file to .env and fill in your actual values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# 1. MongoDB (Document Database for Raw Articles)
# Get from: https://cloud.mongodb.com/
MONGO_URI="mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGO_DB_NAME="finsight_news"

# ===========================================
# VECTOR DATABASE CONFIGURATION
# ===========================================

# 2. Qdrant Cloud (Vector Database for Embeddings)
# Get from: https://cloud.qdrant.io/
QDRANT_URL="https://your-cluster.qdrant.tech"
QDRANT_API_KEY="your_qdrant_api_key_here"

# ===========================================
# AI/ML SERVICES CONFIGURATION
# ===========================================

# 3. Cohere (Cloud Embeddings - Optional but recommended)
# Get from: https://dashboard.cohere.com/
COHERE_API_KEY="your_cohere_api_key_here"

# 4. Groq (LLM Inference - Required)
# Get from: https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Chunk size for text splitting (100-2048 recommended)
CHUNKS=512

# Maximum articles to process per batch
MAX_ARTICLES_PER_BATCH=10

# HTTP request timeout in seconds
REQUEST_TIMEOUT=30

# Log directory (relative to project root)
LOGS_DIR="logs"

# ===========================================
# CORS CONFIGURATION
# ===========================================

# Allowed CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:8000,https://your-frontend-domain.com"

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================

# Set to 'true' for development mode
DEBUG=false

# ===========================================
# SECURITY NOTES
# ===========================================
#
# 1. Never commit the .env file to version control
# 2. Use strong, unique API keys for each service
# 3. Rotate keys regularly
# 4. Use environment-specific configurations
# 5. Consider using a secret management service in production
#
# ===========================================